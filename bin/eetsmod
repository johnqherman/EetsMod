#!/usr/bin/env bash
set -euo pipefail
export LC_ALL=C

SELF="$(cd "$(dirname "$0")/.." && pwd)"

die()  { echo "eetsmod: $*" >&2; exit 1; }
info() { echo "eetsmod: $*"; }
usage() {
	cat <<'EOF'
eetsmod - build, pack, and manage Eets mods.
Players mostly don't need this: drop a .eetsmod in <game>/mods and manage in-game.

  eetsmod uninstall [GAME]                remove the loader
  eetsmod doctor [GAME]                   diagnose the install
  eetsmod new <name>                      scaffold a new mod
  eetsmod build <mod.cpp> [-o so]         compile a mod to a redistributable .so
  eetsmod pack <dir|mod.cpp> [-o f]       bundle .so + source + manifest + assets -> one .eetsmod
  eetsmod add-sound [--music] <mod> <file|folder>   bundle custom sound(s) into <mod>.assets/
  eetsmod add <file|url> [GAME]           install a mod file (.eetsmod, .so, or .cpp)
  eetsmod remove <name> [GAME]            uninstall a mod
  eetsmod list [GAME]                     list installed mods
EOF
}

# ---- locate the game ----
find_game() {
	local g="${1:-${EETS_DIR:-}}"
	if [[ -n "$g" ]]; then [[ -x "$g/Eets" ]] || die "no Eets binary at $g"; echo "$g"; return; fi
	local c
	for c in \
		"$HOME/.local/share/Steam/steamapps/common/Eets" \
		"$HOME/.steam/steam/steamapps/common/Eets" \
		"$HOME/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/common/Eets" \
		"$SELF"; do
		[[ -x "$c/Eets" ]] && { echo "$c"; return; }
	done
	die "could not find Eets; pass the game dir explicitly or set EETS_DIR"
}

# ---- include dir + loader (dev repo or an installed game) ----
includedir() {
	for c in "$SELF/include" "${1:-}/eetsmod-include"; do
		[[ -f "$c/eetsmod.h" ]] && { echo "$c"; return; }
	done
	die "no eetsmod headers found (looked in repo and game dir)"
}
loader_so() {  # build from the repo if present, else use a prebuilt next to this script
	if [[ -f "$SELF/Makefile" && -d "$SELF/loader" ]]; then
		make -C "$SELF" >/dev/null 2>&1 || die "loader build failed (need g++)"
		echo "$SELF/build/libeetsmod.so"
	elif [[ -f "$SELF/libeetsmod.so" ]]; then echo "$SELF/libeetsmod.so"
	else die "no loader: run from the repo or a release directory"; fi
}

# ---- compile a mod the way the loader does ----
compile_so() {  # <src.cpp> <out.so> [game-for-includes]
	local src="$1" out="$2" inc; inc="$(includedir "${3:-}")"
	local opt="-O2"; [[ "${EETSMOD_DEBUG:-0}" != "0" ]] && opt="-g -O0"
	command -v "${CXX:-g++}" >/dev/null || die "need a C++ compiler (g++) to build from source"
	"${CXX:-g++}" $opt -fPIC -std=c++17 -Wall -shared "-I$inc" ${EETSMOD_CXXFLAGS:-} -o "$out" "$src"
}

# where libeetsmod.dll.a (the Windows import lib) lives, for cross-building .dll mods
libdir() {
	[[ -f "$SELF/build/libeetsmod.dll.a" ]] && { echo "$SELF/build"; return; }
	[[ -f "$SELF/libeetsmod.dll.a" ]] && { echo "$SELF"; return; }
	echo ""
}
# ---- cross-compile the same mod to a Windows .dll (best-effort; needs mingw + import lib) ----
compile_dll() {  # <src.cpp> <out.dll> [game-for-includes] ; returns 1 if toolchain/lib missing
	local src="$1" out="$2" inc lib; inc="$(includedir "${3:-}")"; lib="$(libdir)"
	command -v "${WINCXX:-i686-w64-mingw32-g++}" >/dev/null || return 1
	[[ -n "$lib" ]] || return 1
	"${WINCXX:-i686-w64-mingw32-g++}" -O2 -std=c++17 "-I$inc" -shared -static-libgcc -static-libstdc++ \
		-o "$out" "$src" -L"$lib" -leetsmod \
		-Wl,-Bstatic,--whole-archive,-l:libwinpthread.a,--no-whole-archive,-Bdynamic 2>/dev/null
}

cmd_uninstall() {
	local game; game="$(find_game "${1:-}")"
	rm -f "$game/libeetsmod.so"
	info "removed the loader; clear the Steam launch option to fully disable."
	info "mods in $game/mods are left in place (remove one with: eetsmod remove <name>)"
}

cmd_doctor() {
	local game; game="$(find_game "${1:-}" 2>/dev/null || true)"
	echo "game dir   : ${game:-NOT FOUND}"
	[[ -n "$game" ]] || return 0
	echo "loader     : $([[ -f "$game/libeetsmod.so" ]] && echo present || echo 'MISSING (drop libeetsmod.so in the game folder)')"
	echo "headers    : $([[ -f "$game/eetsmod-include/eetsmod.h" ]] && echo present || echo missing)"
	echo "mods dir   : $game/mods ($(ls "$game/mods"/*.so "$game/mods"/*.cpp 2>/dev/null | wc -l) mod file(s))"
	echo "compiler   : $(command -v "${CXX:-g++}" >/dev/null && "${CXX:-g++}" --version | head -1 || echo 'none (prebuilt .so mods still work)')"
	echo "tar/curl   : $(command -v tar >/dev/null && echo tar || echo 'no tar') / $(command -v curl >/dev/null && echo curl || (command -v wget >/dev/null && echo wget || echo none))"
}

cmd_new()   { "$SELF/tools/new-mod.sh" "$@"; }

# generate custom sound(s) into <mod>.assets/ so pack bundles them. forms:
#   eetsmod add-sound [--music] <mod> <name> <audiofile>   one sound, explicit name
#   eetsmod add-sound [--music] <mod> <audiofile>          one sound, name = filename
#   eetsmod add-sound [--music] <mod> <folder>             every audio file in folder
cmd_add_sound() {
	local music=""; [[ "${1:-}" == "--music" ]] && { music="--music"; shift; }
	local mod="${1:-}"; shift || true
	[[ -n "$mod" ]] || die "usage: eetsmod add-sound [--music] <mod> [<name>] <file|folder>"
	local assets="${mod%.cpp}.assets" one; one="$SELF/tools/add-sound.sh"
	if [[ $# -eq 2 && -f "$2" ]]; then
		"$one" --into "$assets" $music "$1" "$2"
	elif [[ $# -eq 1 && -d "$1" ]]; then
		local n=0 f name
		for f in "$1"/*; do
			[[ -f "$f" ]] || continue
			case "$(file -b --mime-type "$f" 2>/dev/null)" in audio/*) ;; *) continue;; esac
			name="$(basename "$f")"; name="${name%.*}"
			"$one" --into "$assets" $music "$name" "$f" >/dev/null && n=$((n+1))
		done
		[[ $n -gt 0 ]] && info "added $n sound(s) from $1/ -> $assets" || die "no audio files in $1"
	elif [[ $# -eq 1 && -f "$1" ]]; then
		name="$(basename "$1")"; "$one" --into "$assets" $music "${name%.*}" "$1"
	else die "usage: eetsmod add-sound [--music] <mod> [<name>] <file|folder>"; fi
}

cmd_build() {
	local src="" out=""
	while [[ $# -gt 0 ]]; do case "$1" in -o) out="$2"; shift 2;; *) src="$1"; shift;; esac; done
	[[ -f "$src" ]] || die "usage: eetsmod build <mod.cpp> [-o out.so]"
	[[ -n "$out" ]] || out="$(dirname "$src")/$(basename "${src%.cpp}").so"
	compile_so "$src" "$out"
	info "built $out (drop it in <game>/mods/, no compiler needed to run it)"
}

# bundle layout: <name>.cfg [+ <name>.so] [+ <name>.cpp] [+ assets/...]
cmd_pack() {
	command -v tar >/dev/null || die "need tar to pack"
	local in="" out=""
	while [[ $# -gt 0 ]]; do case "$1" in -o) out="$2"; shift 2;; *) in="$1"; shift;; esac; done
	[[ -n "$in" ]] || die "usage: eetsmod pack <dir|mod.cpp> [-o name.eetsmod]"
	local tmp name; tmp="$(mktemp -d)"; trap "rm -rf '$tmp'" EXIT
	if [[ -f "$in" && "$in" == *.cpp ]]; then
		name="$(basename "${in%.cpp}")"; local base; base="$(dirname "$in")"
		cp "$in" "$tmp/$name.cpp"
		compile_so "$in" "$tmp/$name.so"            # ship a prebuilt .so so users need no compiler
		compile_dll "$in" "$tmp/$name.dll" || info "no Windows .dll (need i686-w64-mingw32-g++ + libeetsmod.dll.a); bundle is Linux-only"
		local cfg="$base/$name.cfg"
		[[ -f "$cfg" ]] && cp "$cfg" "$tmp/$name.cfg" || printf 'version = 1.0\nauthor = unknown\n' > "$tmp/$name.cfg"
		# custom assets ride along: a sibling <name>.assets/ tree (mirrors Data/) -> assets/ in the bundle
		[[ -d "$base/$name.assets" ]] && cp -r "$base/$name.assets" "$tmp/assets"
	elif [[ -d "$in" ]]; then
		local cfg; cfg="$(ls "$in"/*.cfg 2>/dev/null | head -1)" || true
		[[ -n "$cfg" ]] || die "no <name>.cfg in $in"
		name="$(basename "${cfg%.cfg}")"
		cp "$cfg" "$tmp/$name.cfg"
		[[ -f "$in/$name.so" ]]  && cp "$in/$name.so"  "$tmp/"
		[[ -f "$in/$name.dll" ]] && cp "$in/$name.dll" "$tmp/"
		[[ -f "$in/$name.cpp" ]] && cp "$in/$name.cpp" "$tmp/"
		[[ -f "$tmp/$name.so" || -f "$tmp/$name.cpp" ]] || die "no $name.so or $name.cpp in $in"
		[[ -f "$tmp/$name.so" ]] || { [[ -f "$tmp/$name.cpp" ]] && compile_so "$in/$name.cpp" "$tmp/$name.so" 2>/dev/null || true; }
		# cross-build the .dll from source if one wasn't supplied
		[[ -f "$tmp/$name.dll" || ! -f "$tmp/$name.cpp" ]] || compile_dll "$in/$name.cpp" "$tmp/$name.dll" || true
		[[ -d "$in/assets" ]] && cp -r "$in/assets" "$tmp/"
	else die "pack source must be a .cpp or a directory"; fi
	pack_audit "$tmp" "$name"     # warn about sound refs in code that are not bundled
	[[ -n "$out" ]] || out="$name.eetsmod"
	tar -C "$tmp" -cf "$out" .                       # STORED (uncompressed) ustar: the loader untars in-process, no inflate
	# report contents so a forgotten asset is obvious
	local has_so="no" has_dll="no" has_src="no" nassets=0
	[[ -f "$tmp/$name.so" ]] && has_so="yes"
	[[ -f "$tmp/$name.dll" ]] && has_dll="yes"
	[[ -f "$tmp/$name.cpp" ]] && has_src="yes"
	[[ -d "$tmp/assets" ]] && nassets="$(find "$tmp/assets" -type f | wc -l)"
	info "packed $out (name=$name, $(du -h "$out" | cut -f1)): linux_so=$has_so win_dll=$has_dll source=$has_src assets=$nassets"
}

# best-effort lint: the convention dir bundles assets; this just parses code for sound
# string-literals and flags any with no matching patch in the bundle (could be a stock
# game sound, or a forgotten custom one). literals only - dynamic names are invisible.
pack_audit() {
	local tmp="$1" name="$2" src="$1/$name.cpp"
	[[ -f "$src" ]] || return 0
	local n flag missing=""
	for n in $(grep -oE '(PlaySound|Sound_CreateSound)[[:space:]]*\([[:space:]]*"[^"]+"' "$src" 2>/dev/null \
	           | sed -E 's/.*"([^"]+)"/\1/' | sort -u); do
		[[ -f "$tmp/assets/Sound/Patch/$n.ptch" ]] || missing+=" $n"
	done
	for n in $(grep -oE 'Sound_PlayMusic[[:space:]]*\([[:space:]]*"[^"]+"' "$src" 2>/dev/null \
	           | sed -E 's/.*"([^"]+)"/\1/' | sort -u); do
		[[ -f "$tmp/assets/Sound/Music/$n.ogg" ]] || missing+=" $n"
	done
	[[ -n "$missing" ]] && info "note: sound(s) used in code but not bundled (ok if stock game sounds):$missing"
	return 0
}

cmd_add() {
	local src="$1"; shift || true
	local game; game="$(find_game "${1:-}")"
	mkdir -p "$game/mods"
	case "$src" in
		http://*|https://*)
			local tmp; tmp="$(mktemp --suffix=".$(basename "$src")")"
			fetch "$src" "$tmp"; cmd_add "$tmp" "$game"; rm -f "$tmp"; return;;
	esac
	[[ -f "$src" ]] || die "no such file: $src"
	case "$src" in
		# a .eetsmod is self-contained: just drop the one file in, the loader stages it
		*.eetsmod) install -m644 "$src" "$game/mods/"; info "added $(basename "$src")";;
		*.so)  install -m644 "$src" "$game/mods/"; info "added $(basename "$src") (prebuilt)";;
		*.cpp) cp "$src" "$game/mods/"; info "added $(basename "$src") (compiles at next launch)";;
		*) die "unsupported mod file: $src (.eetsmod, .so, .cpp, or URL)";;
	esac
}

cmd_remove() {
	local name="$1"; shift || true
	local game; game="$(find_game "${1:-}")"
	local n=0
	for ext in so cpp cfg save; do [[ -f "$game/mods/$name.$ext" ]] && { rm -f "$game/mods/$name.$ext"; n=$((n+1)); }; done
	rm -f "$game/mods/.cache/$name.so"
	[[ $n -gt 0 ]] && info "removed '$name' ($n file(s))" || die "no mod '$name' in $game/mods"
}

cmd_list() {
	local game; game="$(find_game "${1:-}")"
	local any=0 f name ver kind seen=" "
	for f in "$game"/mods/*.so "$game"/mods/*.cpp; do
		[[ -e "$f" ]] || continue
		name="$(basename "$f")"; name="${name%.*}"
		[[ "$seen" == *" $name "* ]] && continue; seen+="$name "; any=1
		ver="$(sed -n 's/^[[:space:]]*version[[:space:]]*=[[:space:]]*//p' "$game/mods/$name.cfg" 2>/dev/null | head -1)"
		kind="[source]"; [[ -f "$game/mods/$name.so" ]] && kind="[prebuilt]"
		printf '  %-24s %s%s\n' "$name" "${ver:+v$ver }" "$kind"
	done
	[[ $any -eq 1 ]] || info "no mods installed in $game/mods"
}

fetch() {  # <url> <out>
	if command -v curl >/dev/null; then curl -fsSL "$1" -o "$2"
	elif command -v wget >/dev/null; then wget -qO "$2" "$1"
	else die "need curl or wget to download"; fi
}

main() {
	local cmd="${1:-}"; shift || true
	case "$cmd" in
		uninstall) cmd_uninstall "$@";;
		doctor)  cmd_doctor  "$@";;
		new)     cmd_new     "$@";;
		add-sound) cmd_add_sound "$@";;
		build)   cmd_build   "$@";;
		pack)    cmd_pack    "$@";;
		add)     cmd_add     "$@";;
		remove|rm) cmd_remove "$@";;
		list|ls) cmd_list    "$@";;
		-h|--help|help|"") usage;;
		*) die "unknown command '$cmd' (try: eetsmod help)";;
	esac
}
main "$@"
